  "conjugation_whitelist": {
    "_nota": "Terminaciones de base verbal que indican una conjugacion finita transformable. El motor acepta la base SOLO si matchea una de estas terminaciones (despues de pasar force_deaccent y present_historical).",
    "preterite_3s": {
      "pattern": "ends_with_ó",
      "examples": ["levantó", "tomó", "mató", "habló", "sacó"],
      "action": "conservar_tilde"
    },
    "preterite_3pl": {
      "pattern": "deaccent_ends_with_aron_eron_ieron",
      "examples": ["dijeron", "hicieron", "pusieron", "levantaron"],
      "action": "quitar_tilde_arcaica"
    },
    "imperfect_ia": {
      "pattern": "ends_with_ía_ían",
      "examples": ["tenía", "decía", "hacía", "había"],
      "action": "conservar_tilde"
    },
    "imperfect_aba": {
      "pattern": "deaccent_ends_with_aba_aban",
      "examples": ["llamaba", "estaba", "llevaba"],
      "action": "quitar_tilde_si_hay"
    },
    "future": {
      "pattern": "ends_with_á_án_é",
      "examples": ["hará", "pondrá", "haré", "pondré"],
      "action": "conservar_tilde"
    }
  }
